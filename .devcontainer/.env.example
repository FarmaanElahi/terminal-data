# Devcontainer environment file
# Copy to `.devcontainer/.env` before opening in container:
#   cp .devcontainer/.env.example .devcontainer/.env

# Logging / runtime
ENVIRONMENT=development
LOG_LEVEL=INFO
LOG_FORMAT=text
PORT=8000
BASE_URL=http://localhost:8000

# Security (use real values in shared/dev environments)
SECRET_KEY=dev-only-secret-key
ENCRYPTION_KEY=dev-only-fernet-key

# OCI (required by current Settings model)
OCI_BUCKET=terminal-files
OCI_CONFIG=base64_or_raw_oci_config
OCI_KEY=base64_or_raw_oci_private_key

# OAuth (optional in dev)
UPSTOX_ACCESS_TOKEN=
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
UPSTOX_REDIRECT_URI=http://localhost:5173/broker/upstox/callback

KITE_API_KEY=
KITE_API_SECRET=
KITE_REDIRECT_URI=http://localhost:5173/broker/kite/callback

# Notifications (optional)
TELEGRAM_BOT_TOKEN=
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
VAPID_CLAIMS_EMAIL=mailto:you@example.com
