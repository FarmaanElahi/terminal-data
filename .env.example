# -------------------------------------------------------------------
# Terminal environment — single source of truth for all config.
# Used by: devcontainer, local docker compose, production.
# -------------------------------------------------------------------
# Quick start:
# 1) cp .env.example .env
# 2) Fill all required values below
# 3) Open in devcontainer, or run: docker compose up -d
#
# In production: inject these as environment variables via your
# deployment system (CI/CD secrets, ECS task env, etc.) instead
# of shipping a .env file.
# -------------------------------------------------------------------

# App
PORT=6699
# development | staging | production
ENVIRONMENT=development
# LOG_FORMAT: text | json
LOG_LEVEL=INFO
LOG_FORMAT=text

# Postgres (managed by docker compose)
DB_SCHEME=postgresql
DB_DRIVER=psycopg
# Keep DB_HOST as `db` for the internal Postgres service.
DB_HOST=db
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=change_me
DB_NAME=terminal
# Optional alert webhook used by some published images
ALERT_WEBOOK_URL=

# Security (required in production)
# Generate SECRET_KEY (example):
# python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=change_me_with_long_random_secret
# Generate ENCRYPTION_KEY (example):
# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=change_me_with_fernet_key
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
MIN_PASSWORD_LENGTH=8

# OCI storage (required by current Settings)
OCI_BUCKET=terminal-files
# OCI_CONFIG / OCI_KEY can be raw text or base64-encoded single-line values.
OCI_CONFIG=base64_or_raw_oci_config
OCI_KEY=base64_or_raw_oci_private_key

# Upstox (optional)
UPSTOX_ACCESS_TOKEN=
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
# Set to your frontend callback URL in deployed environments.
UPSTOX_REDIRECT_URI=http://localhost:5173/broker/upstox/callback

# Kite (optional)
KITE_API_KEY=
KITE_API_SECRET=
# Set to your frontend callback URL in deployed environments.
KITE_REDIRECT_URI=http://localhost:5173/broker/kite/callback

# Notifications (optional)
TELEGRAM_BOT_TOKEN=
VAPID_PRIVATE_KEY=
VAPID_PUBLIC_KEY=
# Example: mailto:alerts@your-domain.com
VAPID_CLAIMS_EMAIL=mailto:you@example.com
